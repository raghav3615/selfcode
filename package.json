{
  "name": "selfcode",
  "version": "0.2.0",
  "description": "An open-source Claude Code / OpenCode-like AI coding assistant with TUI - supports 20+ LLM providers",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "selfcode": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "ai",
    "coding-assistant",
    "llm",
    "tui",
    "terminal",
    "openai",
    "anthropic",
    "groq",
    "ollama",
    "deepseek",
    "gemini",
    "copilot",
    "openrouter"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "glob": "^11.0.1",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.6",
    "marked-terminal": "^7.3.0",
    "openai": "^4.85.4",
    "ora": "^8.2.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^19.2.14",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  }
}
