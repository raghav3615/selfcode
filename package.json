{
  "name": "selfcode",
  "version": "0.1.0",
  "description": "An open-source Claude Code / OpenCode-like AI coding assistant CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "selfcode": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["cli", "ai", "coding-assistant", "llm", "openai", "anthropic"],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "glob": "^11.0.1",
    "marked": "^15.0.6",
    "marked-terminal": "^7.3.0",
    "openai": "^4.85.4",
    "ora": "^8.2.0",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  }
}
